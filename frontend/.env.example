VITE_API_BASE_URL=http://localhost:8080/api
VITE_APP_NAME=Smart Campus Operations Hub
VITE_APP_VERSION=1.0.0

# Google OAuth Configuration
# Get your Client ID from: https://console.cloud.google.com/
# Instructions: See GOOGLE_OAUTH_SETUP_GUIDE.md in the project root
# Steps:
#   1. Create a project in Google Cloud Console
#   2. Enable Google+ API
#   3. Create OAuth 2.0 Web Application credentials
#   4. Add authorized JavaScript origins: http://localhost:5173
#   5. Add authorized redirect URIs: http://localhost:5173/dashboard
#   6. Copy the Client ID and paste it below
VITE_GOOGLE_CLIENT_ID=your_google_client_id_from_google_cloud_here
